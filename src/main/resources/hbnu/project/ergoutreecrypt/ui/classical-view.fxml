<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="ccRoot" xmlns:fx="http://javafx.com/fxml"
           fx:controller="hbnu.project.ergoutreecrypt.ui.ClassicalCryptController">
    <VBox styleClass="tab-body">

        <ScrollPane styleClass="content-scroll" fitToWidth="true" VBox.vgrow="ALWAYS">
            <HBox alignment="TOP_CENTER">
                <VBox styleClass="content" spacing="16" maxWidth="720" HBox.hgrow="ALWAYS">
                    <padding><Insets top="18" right="24" bottom="18" left="24"/></padding>

                    <!-- 算法选择 -->
                    <VBox styleClass="card" spacing="8">
                        <Label fx:id="ccAlgorithmLabel" styleClass="card-title"/>
                        <ComboBox fx:id="ccAlgorithmCombo" styleClass="text-input" maxWidth="Infinity"/>
                    </VBox>

                    <!-- 算法参数 -->
                    <VBox fx:id="ccParamCard" styleClass="card" spacing="10" managed="false" visible="false">
                        <!-- 位移量（凯撒） -->
                        <VBox fx:id="ccShiftBox" spacing="4" managed="false" visible="false">
                            <Label fx:id="ccShiftLabel" styleClass="card-title"/>
                            <TextField fx:id="ccShiftField" styleClass="text-input"/>
                        </VBox>
                        <!-- 关键词（维吉尼亚/自动密钥/博福特/列移位） -->
                        <VBox fx:id="ccKeywordBox" spacing="4" managed="false" visible="false">
                            <Label fx:id="ccKeywordLabel" styleClass="card-title"/>
                            <TextField fx:id="ccKeywordField" styleClass="text-input"/>
                        </VBox>
                        <!-- 栅栏层数（栅栏密码） -->
                        <VBox fx:id="ccRailsBox" spacing="4" managed="false" visible="false">
                            <Label fx:id="ccRailsLabel" styleClass="card-title"/>
                            <TextField fx:id="ccRailsField" styleClass="text-input"/>
                        </VBox>
                        <!-- 异或密钥（XOR） -->
                        <VBox fx:id="ccKeyBox" spacing="4" managed="false" visible="false">
                            <Label fx:id="ccKeyLabel" styleClass="card-title"/>
                            <TextField fx:id="ccKeyField" styleClass="text-input"/>
                        </VBox>
                    </VBox>

                    <!-- 明文 / 密文 双栏 -->
                    <HBox spacing="12" VBox.vgrow="ALWAYS">
                        <!-- 明文 -->
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label fx:id="ccPlaintextLabel" styleClass="card-title"/>
                            <TextArea fx:id="ccPlaintextArea" styleClass="text-input" wrapText="true"
                                      prefRowCount="12" VBox.vgrow="ALWAYS"/>
                        </VBox>
                        <!-- 密文 -->
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label fx:id="ccCiphertextLabel" styleClass="card-title"/>
                            <TextArea fx:id="ccCiphertextArea" styleClass="text-input" wrapText="true"
                                      prefRowCount="12" VBox.vgrow="ALWAYS"/>
                        </VBox>
                    </HBox>
                </VBox>
            </HBox>
        </ScrollPane>

        <!-- 底部操作栏 -->
        <VBox styleClass="footer" spacing="10">
            <padding><Insets top="14" right="24" bottom="18" left="24"/></padding>
            <HBox spacing="12" alignment="CENTER">
                <Button fx:id="ccDecryptBtn" styleClass="btn-secondary" onAction="#onDecrypt"/>
                <Button fx:id="ccSwapBtn" styleClass="btn-ghost" onAction="#onSwap"/>
                <Button fx:id="ccEncryptBtn" styleClass="btn-accent" onAction="#onEncrypt"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="ccCopyBtn" styleClass="btn-ghost" onAction="#onCopy"/>
                <Button fx:id="ccClearBtn" styleClass="btn-ghost" onAction="#onClear"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
